@{
    TagBuilder tag = Tag(Model, Model.Style == "unordered" ? "ul" : "ol");

    string textAlignment = Model.TextAlignment;
    if (textAlignment != null)
    {
        tag.MergeAttribute("style", $"text-align:{textAlignment}");
    }
}

@tag.RenderStartTag()

@foreach (var item in Model.ListItems)
{
    <li>@Html.Raw(item)</li>
}

@tag.RenderEndTag()