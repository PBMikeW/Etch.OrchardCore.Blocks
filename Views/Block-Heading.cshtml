@inject OrchardCore.Modules.Services.ISlugService SlugService

@{
    TagBuilder tag = Tag(Model, $"h{Model.Level.ToString()}");
    tag.Attributes["id"] = SlugService.Slugify(Model.Text);

    string textAlignment = Model.TextAlignment;
    if (textAlignment != null)
    {
        tag.MergeAttribute("style", $"text-align:{textAlignment}");
    }
}

@tag.RenderStartTag()
    @Html.Raw(Model.Text)
@tag.RenderEndTag()